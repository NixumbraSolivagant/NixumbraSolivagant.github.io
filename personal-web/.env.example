# ── Umami Integration ──────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# Without these, the globe will display mock data.
#
# ── Self-hosted ───────────────────────────────────────────────────────────────
# If you run your own Umami instance:
#   VITE_UMAMI_BASE=https://analytics.yourdomain.com
#   VITE_UMAMI_WEBSITE_ID=your-website-uuid
#   VITE_UMAMI_API_KEY=your-api-key
#
# ── Umami Cloud ───────────────────────────────────────────────────────────────
# If you use Umami Cloud (https://cloud.umami.is):
#   VITE_UMAMI_BASE=https://api.umami.is/v1
#   VITE_UMAMI_WEBSITE_ID=your-website-uuid
#   VITE_UMAMI_API_KEY=api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# How to find these values:
#   1. Log in to Umami dashboard
#   2. Click "Websites" in the sidebar → click your website name
#      (the UUID is in the URL or in the website settings)
#   3. Go to Settings → API Keys → Create an API Key
#

# Base URL of your Umami API (no trailing slash)
VITE_UMAMI_BASE=

# Website UUID (found in Website Settings)
VITE_UMAMI_WEBSITE_ID=

# API Key (generated in Settings → API Keys)
VITE_UMAMI_API_KEY=
