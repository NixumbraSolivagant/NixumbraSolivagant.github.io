# ── Umami Integration ──────────────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# Without these, the globe will display mock data.
#
# How to find these values:
#  1. Log in to your Umami dashboard
#  2. Go to Website Settings → Share
#  3. Click "Get Code" on the share link
#  4. The share URL looks like:
#     https://your-umami.com/share/SHARE_ID/website-slug
#

# Full base URL of your Umami instance (no trailing slash)
# Example: VITE_UMAMI_BASE=https://analytics.yourdomain.com
VITE_UMAMI_BASE=

# The UUID-style share ID from the share URL
# Example: VITE_UMAMI_SHARE_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
VITE_UMAMI_SHARE_ID=

# The website slug shown in the share URL
# Example: VITE_UMAMI_SLUG=my-website
VITE_UMAMI_SLUG=
